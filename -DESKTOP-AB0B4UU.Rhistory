library(readxl)
GS1_Trait_Datasheet_Bolting <- read.csv("C:/Users/Sophie/OneDrive - Michigan State University/Arabidopsis/Swe_Italy/RawData_DoNotEdit/GrowingSeason1/GS1_Trait_Datasheet_Bolting.csv")
GS1_Trait_Datasheet_Bolting <- GS1_Trait_Datasheet_Bolting[ , c("PotLabel", "Trt", "Flat", "Pos", "Fresh.date", "scan.", "Notes")]
GS1_LeafScans <- read.csv("C:/Users/Sophie/OneDrive - Michigan State University/Arabidopsis/Swe_Italy/RawData_DoNotEdit/GrowingSeason1/GS1_LeafScans.csv")
GS1_LeafScans <- GS1_LeafScans[ ,1:6]
GS1_LeafScans$PotLabel <- substr(GS1_LeafScans$PlantID, start = 1, stop = 7)
missing1 <- merge(GS1_Trait_Datasheet_Bolting, GS1_LeafScans, by = "PotLabel", all = TRUE)
View(missing1)
